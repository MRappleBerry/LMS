{
  "buildCommand": "npm --prefix lms-app/client install && npm --prefix lms-app/client run build",
  "outputDirectory": "lms-app/client/dist",
  "installCommand": "npm install",
  "framework": null,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
